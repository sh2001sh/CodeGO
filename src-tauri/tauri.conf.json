{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeGo",
  "version": "1.0.12",
  "identifier": "com.sh2001sh.codego",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3215",
    "beforeDevCommand": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1 --port 3215",
    "beforeBuildCommand": "node ./node_modules/vite/bin/vite.js build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CodeGo",
        "titleBarStyle": "Overlay",
        "width": 1000,
        "height": 650,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: http:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https: http:",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN",
        "template": "wix/per-user-main.wxs"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["codego", "ccswitch"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1MzVCNUU4RjFBNzQyQkEKUldTNlFxZng2TFUxMVkzK0x6TmVPRjhXeVlsUGhRUU96RUY2SVh0MGRidXVLbWtKenkrWWN5TzcK",
      "endpoints": ["https://shu26.cfd/api/desktop/release/latest.json"]
    }
  }
}
